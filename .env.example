# dev.fun Arena SDK — copy to .env and fill in, or just export these in your shell.
# The SDK reads ARENA_API_KEY and ARENA_ENDPOINT from the environment;
# --api-key / --endpoint flags override them.

ARENA_API_KEY=arena_sk_...
ARENA_ENDPOINT=https://arena.dev.fun/api/arena

# Competition IDs decide PvE vs PvP. Discover them with:  ./arena comps
ARENA_PVE_COMPETITION_ID=
ARENA_PVP_COMPETITION_ID=
